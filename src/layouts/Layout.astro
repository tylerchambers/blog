---
import { SITE } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title = SITE.name,
  description = SITE.description,
  type = 'website',
  publishedTime,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? SITE.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS feed`} href="/rss.xml" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          // The system preference remains the fallback when storage is unavailable.
        }
      })();
    </script>
    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-HYTeXgFrPqtC8mJaIc4c5.js"></script>
    <script is:inline>
      window.plausible =
        window.plausible ||
        function () {
          (plausible.q = plausible.q || []).push(arguments);
        };
      plausible.init =
        plausible.init ||
        function (i) {
          plausible.o = i || {};
        };
      plausible.init();
    </script>
    <style is:global>
      :root {
        --background: #fffff8;
        --surface: #fff;
        --surface-muted: #f7f7ef;
        --text: #171713;
        --text-muted: #5a5a50;
        --border: #8d8d80;
        --border-strong: #262621;
        --border-subtle: #d8d8cc;
        --link: #0000aa;
        --link-visited: #6b288a;
        --focus: #9b5200;
        color-scheme: light;
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme]) {
          --background: #171714;
          --surface: #20201c;
          --surface-muted: #282821;
          --text: #ecece2;
          --text-muted: #b8b8aa;
          --border: #777769;
          --border-strong: #d4d4c8;
          --border-subtle: #45453b;
          --link: #8cb4ff;
          --link-visited: #d7a4eb;
          --focus: #f1b45b;
          color-scheme: dark;
        }
      }

      :root[data-theme='dark'] {
        --background: #171714;
        --surface: #20201c;
        --surface-muted: #282821;
        --text: #ecece2;
        --text-muted: #b8b8aa;
        --border: #777769;
        --border-strong: #d4d4c8;
        --border-subtle: #45453b;
        --link: #8cb4ff;
        --link-visited: #d7a4eb;
        --focus: #f1b45b;
        color-scheme: dark;
      }

      html {
        background: var(--background);
      }

      body {
        margin: 0;
        background: var(--background);
        color: var(--text);
        font-family: Georgia, 'Times New Roman', Times, serif;
        font-size: 18px;
        line-height: 1.55;
      }

      main {
        max-width: 42rem;
        margin: 4rem auto;
        padding: 0 1.25rem;
      }

      header {
        border-bottom: 1px solid var(--border-strong);
        margin-bottom: 2rem;
        padding-bottom: 0.75rem;
      }

      .theme-controls {
        display: flex;
        justify-content: flex-end;
        margin-bottom: 1rem;
      }

      .theme-toggle {
        align-items: center;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--text-muted);
        cursor: pointer;
        display: inline-flex;
        font: inherit;
        font-size: 0.8rem;
        gap: 0.4rem;
        padding: 0.25rem 0.65rem;
      }

      .theme-toggle:hover {
        border-color: var(--border-strong);
        color: var(--text);
      }

      .theme-toggle__icon {
        font-size: 0.95rem;
        line-height: 1;
      }

      .site-header__links {
        display: flex;
        gap: 1rem;
        margin-top: 0.75rem;
      }

      h1,
      h2,
      h3 {
        font-weight: normal;
        line-height: 1.2;
      }

      h1 {
        font-size: 2rem;
        margin: 0 0 0.25rem;
      }

      h2 {
        font-size: 1.35rem;
        margin-top: 2rem;
      }

      a {
        color: var(--link);
        text-decoration: underline;
      }

      a:visited {
        color: var(--link-visited);
      }

      a:focus-visible,
      button:focus-visible {
        outline: 2px solid var(--focus);
        outline-offset: 3px;
      }

      p,
      ul,
      ol,
      pre,
      blockquote {
        margin: 1rem 0;
      }

      ul,
      ol {
        padding-left: 1.4rem;
      }

      time {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-variant-numeric: tabular-nums;
      }

      code,
      pre {
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.95em;
      }

      pre {
        overflow-x: auto;
        border: 1px solid var(--border);
        background: var(--surface);
        padding: 0.75rem;
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-theme]) .astro-code,
        :root:not([data-theme]) .astro-code span {
          color: var(--shiki-dark) !important;
          background-color: var(--shiki-dark-bg) !important;
        }
      }

      :root[data-theme='dark'] .astro-code,
      :root[data-theme='dark'] .astro-code span {
        color: var(--shiki-dark) !important;
        background-color: var(--shiki-dark-bg) !important;
      }

      .code-block {
        margin: 1rem 0;
      }

      .code-block__title {
        border: 1px solid var(--border);
        border-bottom: 0;
        background: var(--surface-muted);
        color: var(--text-muted);
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.85rem;
        padding: 0.35rem 0.75rem;
      }

      .code-block pre {
        margin: 0;
      }

      .code-block--line-numbers code {
        counter-reset: code-line;
      }

      .code-block--line-numbers .line {
        counter-increment: code-line;
        display: inline-block;
        min-width: 100%;
      }

      .code-block--line-numbers .line::before {
        content: counter(code-line);
        display: inline-block;
        width: 2.5ch;
        margin-right: 1rem;
        padding-right: 0.75rem;
        border-right: 1px solid var(--border-subtle);
        color: var(--text-muted);
        text-align: right;
        user-select: none;
      }

      blockquote {
        border-left: 1px solid var(--border);
        color: var(--text-muted);
        margin-left: 0;
        padding-left: 1rem;
      }

      .post-list {
        list-style: none;
        padding-left: 0;
      }

      .post-list li {
        margin: 0.4rem 0;
      }
    </style>
  </head>
  <body>
    <main>
      <div class="theme-controls">
        <button class="theme-toggle" type="button" aria-label="Use dark theme">
          <span class="theme-toggle__icon" aria-hidden="true">◐</span>
          <span class="theme-toggle__label">Dark</span>
        </button>
      </div>
      <slot />
    </main>
    <script is:inline>
      (() => {
        const toggle = document.querySelector('.theme-toggle');
        const label = toggle?.querySelector('.theme-toggle__label');
        const systemTheme = window.matchMedia('(prefers-color-scheme: dark)');

        if (!(toggle instanceof HTMLButtonElement) || label === null || label === undefined) {
          return;
        }

        const currentTheme = () =>
          document.documentElement.dataset.theme ?? (systemTheme.matches ? 'dark' : 'light');

        const updateToggle = () => {
          const nextTheme = currentTheme() === 'dark' ? 'light' : 'dark';
          const nextThemeName = `${nextTheme[0].toUpperCase()}${nextTheme.slice(1)}`;
          toggle.setAttribute('aria-label', `Use ${nextTheme} theme`);
          label.textContent = nextThemeName;
        };

        toggle.addEventListener('click', () => {
          const theme = currentTheme() === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = theme;

          try {
            localStorage.setItem('theme', theme);
          } catch {
            // The selected theme still applies for the lifetime of this page.
          }

          updateToggle();
        });

        systemTheme.addEventListener('change', updateToggle);
        updateToggle();
      })();
    </script>
  </body>
</html>

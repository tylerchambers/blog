---
import PostList from '../components/PostList.astro';
import { SITE } from '../config/site';
import { getPublishedPosts } from '../lib/posts';
import Layout from '../layouts/Layout.astro';

const posts = await getPublishedPosts();
---

<Layout title={SITE.name} description={SITE.description}>
  <header class="site-header">
    <h1>{SITE.name}</h1>
    <p>{SITE.tagline}</p>
    <nav class="site-header__links" aria-label="Profile links">
      <a href="https://tally.so/r/XxyLlz">Contact</a>
      <a href="https://github.com/tylerchambers">Github</a>
      <a href="https://www.linkedin.com/in/tyler-chambers1/">LinkedIn</a>
    </nav>
  </header>

  <section aria-labelledby="writing">
    <h2 id="writing">Writing</h2>
    <PostList posts={posts} />
  </section>
</Layout>
